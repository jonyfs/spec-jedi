.remember/
*.log
.DS_Store

# graphify knowledge graph — regenerated locally via the post-commit hook
# and the CLAUDE.md "always check the graph" instruction (see `graphify
# hook status` / `graphify claude install`). Not committed: it's a derived
# cache, not source of truth.
graphify-out/

# Third-party dev-tool skills installed locally via `npx skills add`
# (e.g. trailofbits/skills, Community-Access/accessibility-agents) for
# working on this project — personal local tooling, not part of the Spec
# Jedi product surface (Principle XV: specjedi-* is the product,
# speckit-* is vendored bootstrap tooling; anything else here is neither).
.agents/
.claude/skills/*
!.claude/skills/specjedi-*
!.claude/skills/speckit-*
skills-lock.json

# specjedi-worktree's git-fallback path (no native harness worktree tool
# available) creates worktrees here — project-local, never committed.
.worktrees/
