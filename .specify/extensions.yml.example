#     - command: "specjedi.checklist"
#       optional: true
#       description: "Suggest a quality-focused checklist right after task breakdown, before implementation starts."
#       prompt: "Tasks are ready. Want a checklist pass on this breakdown before implementing?"
#
#   before_implement:
#     - command: "specjedi.analyze"
#       optional: true
#       description: "Run the existing read-only spec/plan/tasks consistency check immediately before implementation begins."
#       prompt: "About to implement — run a quick consistency check across spec/plan/tasks first?"
#
